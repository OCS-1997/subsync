<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_overlay_rounded"
    android:elevation="24dp"
    android:clipToOutline="true">

    <!-- Header Section (Gradient Blue) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingBottom="42dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">
        
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUBSYNC CRM"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.1"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.85"
                android:layout_centerVertical="true" />
            <ImageButton
                android:id="@+id/btn_dismiss_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:alpha="0.8"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:tint="#FFFFFF" />
        </RelativeLayout>

        <!-- Profile / Avatar Section -->
        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_initial_circle"
            android:elevation="8dp"
            android:layout_marginBottom="20dp">
            <TextView
                android:id="@+id/tv_initials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="U"
                android:textColor="#1D4ED8"
                android:textSize="36sp"
                android:fontFamily="sans-serif-condensed-light"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_contact_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unknown"
            android:textSize="26sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:layout_marginBottom="4dp" />
            
        <TextView
            android:id="@+id/tv_phone_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+1 234 567 890"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif"
            android:alpha="0.85"
            android:letterSpacing="0.05"
            android:gravity="center" />
            
        <TextView
            android:id="@+id/tv_company_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Company Name"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:alpha="0.80"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Action Section (White Overlay) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:gravity="top|center_horizontal"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <TextView
            android:id="@+id/tv_status_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_pill"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:text="Call ended recently"
            android:textColor="#4B5563"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btn_log_call"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Log Call Details"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:backgroundTint="#2563EB"
            android:background="@drawable/bg_btn_primary"
            android:layout_marginBottom="12dp"
            android:elevation="4dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btn_dismiss"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Discard"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textColor="#6B7280"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_btn_secondary"
            android:layout_marginBottom="8dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <TextView android:id="@+id/tv_duration_type" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

</LinearLayout>
