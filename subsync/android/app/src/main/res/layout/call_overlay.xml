<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_rounded_top"
    android:padding="24dp"
    android:elevation="12dp">

    <!-- Handle drag indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#E2E8F0"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tv_status_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Call Ended"
        android:textSize="11sp"
        android:textColor="#3B82F6"
        android:background="@drawable/bg_status_pill"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:fontFamily="sans-serif-medium"
        android:textAllCaps="true"
        android:letterSpacing="0.05"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_contact_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="John Doe"
        android:textSize="28sp"
        android:textColor="#0F172A"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="2dp"/>

    <TextView
        android:id="@+id/tv_company_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Company Name"
        android:textSize="14sp"
        android:textColor="#3B82F6"
        android:fontFamily="sans-serif-medium"
        android:visibility="gone"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_phone_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+1 234 567 890"
        android:textSize="14sp"
        android:textColor="#64748B"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="20dp"/>

    <View 
        android:layout_width="match_parent" 
        android:layout_height="1dp" 
        android:background="#F1F5F9"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="32dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_clock"
            android:tint="#3B82F6"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tv_duration_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Outgoing • 2 mins 30 secs"
            android:textSize="14sp"
            android:textColor="#334155"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_dismiss"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Discard"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textColor="#64748B"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_btn_secondary"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_log_call"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1.6"
            android:text="Log Call"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-bold"
            android:background="@drawable/bg_btn_primary"
            android:stateListAnimator="@null"
            android:elevation="0dp"
            android:layout_marginStart="8dp"/>

    </LinearLayout>
</LinearLayout>
