{
  "manifest_version": 3,
  "name": "Subsync Extension",
  "version": "1.0.0",
  "description": "Companion extension for Subsync - Manage timers and calls easily.",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": []
}
